{
  "$schema": "https://turbo.build/schema.v2.json",
  "envMode": "loose",
  "globalEnv": ["COMPACTC_VERSION"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only",
      "inputs": ["src/**/*.ts", "!src/**/*.test.ts", "src/**/*.compact"],
      "outputs": ["dist/**", "build/**", "src/**/managed/**"]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "outputLogs": "new-only",
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "compose.yml"],
      "outputs": ["reports/**", "coverage/**", "logs/**"]
    }
  }
}
