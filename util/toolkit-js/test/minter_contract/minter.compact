import CompactStandardLibrary;

export ledger storage_coin_color: Bytes<32>;
export ledger storage_amount: Uint<128>;
export ledger storage_user: Bytes<32>;

export circuit mintUnshieldedToSelfTest(domainSep: Bytes<32>, amount: Uint<64>): Bytes<32> {
  const color = mintUnshieldedToken(disclose(domainSep), disclose(amount), left<ContractAddress, UserAddress>(kernel.self()));
  return color;
}

export circuit mintUnshieldedToUserTest(domainSep: Bytes<32>, address_bytes: Bytes<32>, amount: Uint<64>): Bytes<32> {
  const address = UserAddress { bytes: address_bytes };
  return mintUnshieldedToken(disclose(domainSep), disclose(amount), right<ContractAddress, UserAddress>(disclose(address)));
}

export circuit sendUnshieldedToUser(color: Bytes<32>, address_bytes: Bytes<32>, amount: Uint<128>): [] {
  const address = UserAddress { bytes: address_bytes };
  sendUnshielded(disclose(color), disclose(amount), right<ContractAddress, UserAddress>(disclose(address)));
}

export circuit mintShieldedToSelfTest(domainSep: Bytes<32>, amount: Uint<64>): ShieldedCoinInfo {
    const recipient = ownPublicKey();
    return mintShieldedToken(
        disclose(domainSep),
        disclose(amount),
        evolveNonce(0 as Uint<128>, disclose(domainSep)),
        left<ZswapCoinPublicKey, ContractAddress>(recipient)
    );
}

export circuit mintShieldedToUserTest(domainSep: Bytes<32>, amount: Uint<64>, user_key: ZswapCoinPublicKey): ShieldedCoinInfo {
    return mintShieldedToken(
        disclose(domainSep),
        disclose(amount),
        evolveNonce(0 as Uint<128>, disclose(domainSep)),
        left<ZswapCoinPublicKey, ContractAddress>(disclose(user_key))
    );
}

export circuit receiveShieldedTest(coin: ShieldedCoinInfo): [] {
  assert(coin.value > 0, "Deposit amount must be positive");
  receiveShielded(disclose(coin));
}

/**
 * Mint to contract and send immediately to user using sendImmediateShielded()
 */
export circuit mintAndSendImmediate(domainSep: Bytes<32>, mint_amount: Uint<64>, send_amount: Uint<64>, user_key: ZswapCoinPublicKey): ShieldedCoinInfo {
    const coin = mintShieldedToken(
        disclose(domainSep),
        disclose(mint_amount),
        evolveNonce(0 as Uint<128>, disclose(domainSep)),
        right<ZswapCoinPublicKey, ContractAddress>(kernel.self())
    );
    sendImmediateShielded(coin, left<ZswapCoinPublicKey, ContractAddress>(disclose(user_key)), disclose(send_amount));
    return coin;
}

export circuit setToken(color: Bytes<32>, transfer_amount: Uint<128>, user_address: Bytes<32>): [] {
   storage_coin_color = disclose(color);
   storage_amount = disclose(transfer_amount);
   storage_user = disclose(user_address);
}

export circuit receiveAndSendUnshielded(): [] {
    receiveUnshielded(storage_coin_color, storage_amount);
    sendUnshielded(
        storage_coin_color,
        storage_amount,
        right<ContractAddress, UserAddress>(UserAddress { bytes: storage_user })
    );
}
